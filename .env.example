# Example environment variables for local development.
# Copy this file to `.env` and fill in secrets. DO NOT commit your `.env` file.

POSTGRES_USER=agent
POSTGRES_PASSWORD=agentpass
POSTGRES_DB=agentdb
POSTGRES_PORT=5432
# DATABASE_URL can override individual POSTGRES_* settings. Example for docker-compose:
DATABASE_URL=postgresql+asyncpg://agent:agentpass@postgres:5432/agentdb

# OpenAI: set to your key if you want the OpenAI adapter to call the real API.
# Leave empty or unset to use the OpenAI placeholder fallback.
OPENAI_API_KEY=